# Copy this file to .env and replace every CHANGE_ME value before startup.

APP_VERSION=1.0.0
APP_IMAGE=kbpack/app
WEB_IMAGE=kbpack/web

# Use internal for a private Caddy CA. For public DNS, set an ACME email.
CADDY_TLS=internal
APP_HOST=kb.nas.local
PREVIEW_HOST=kb-preview.nas.local
APP_BASE_URL=https://kb.nas.local
PREVIEW_BASE_URL=https://kb-preview.nas.local
HTTP_PORT=80
HTTPS_PORT=443
COOKIE_SECURE=true

POSTGRES_DB=kbpack
POSTGRES_USER=kbpack
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MEILI_MASTER_KEY=CHANGE_ME_MEILISEARCH_MASTER_KEY

# Generate with: openssl rand -base64 48
PREVIEW_TICKET_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_BYTES
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=CHANGE_ME_INITIAL_OWNER_PASSWORD

UPLOAD_MAX_PACKAGE_SIZE_BYTES=524288000
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0

# Backup scripts default to ./backup and seven-day retention. Export
# BACKUP_ROOT or BACKUP_RETENTION_DAYS in the scheduler to override them.
